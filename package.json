{
	"name": "electrobun-solid",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with SolidJS and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@kobalte/core": "^0.13.11",
		"@nanostores/solid": "^1.1.1",
		"@solid-primitives/storage": "^4.3.4",
		"@solidjs/router": "^0.16.1",
		"@tanstack/solid-query": "^5.99.2",
		"@thisbeyond/solid-dnd": "^0.7.5",
		"electrobun": "1.16.0",
		"lucide-solid": "^1.8.0",
		"nanostores": "^1.3.0",
		"node-vibrant": "^4.0.4",
		"solid-motionone": "^1.0.4",
		"spark-md5": "^3.0.2"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/spark-md5": "^3.0.5",
		"concurrently": "^9.1.0",
		"solid-js": "^1.9.3",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-plugin-solid": "^2.11.0"
	}
}
